#!/bin/bash
# Entry script for autonomous-local-llm

# Source bashrc to get environment variables (GITHUB_TOKEN, etc.)
if [ -f "$HOME/.bashrc" ]; then
    source "$HOME/.bashrc"
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOL_DIR="$HOME/.openclaw/workspace/TOOLS/smart-dev"

case "$1" in
    init)
        python3 "$TOOL_DIR/multi_agent.py" --init
        ;;
    start)
        python3 "$TOOL_DIR/multi_agent.py"
        ;;
    once)
        python3 "$TOOL_DIR/multi_agent.py" --once
        ;;
    logs)
        tail -f .autonomous.log
        ;;
    *)
        echo "Usage: $0 {init|start|once|logs}"
        echo ""
        echo "  init   - Create GOAL.md template"
        echo "  start  - Run agent loop"
        echo "  once   - Run one iteration"
        echo "  logs   - Show live logs"
        exit 1
        ;;
esac
